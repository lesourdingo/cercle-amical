# Public URL, used for OG Image and llms.txt (set to your production domain)
NUXT_PUBLIC_SITE_URL=https://cercle-amical.pages.dev

# NuxtHub blob — médias Nuxt Studio sur Cloudflare R2
NUXT_HUB_BLOB_BUCKET_NAME=cercle-amical-media
# URL publique du bucket R2 (r2.dev ou domaine custom), requise pour les liens d'images
S3_PUBLIC_URL=https://pub-9fa2f3a2873245d58ee8b9ecc5d533a7.r2.dev

# Nuxt Studio (production /admin)
STUDIO_GOOGLE_CLIENT_ID=
STUDIO_GOOGLE_CLIENT_SECRET=
STUDIO_GITHUB_TOKEN=
# On Cloudflare Pages, prefer the NUXT_ prefix (maps to runtimeConfig):
NUXT_STUDIO_GOOGLE_MODERATORS=you@gmail.com
# Local alternative:
# STUDIO_GOOGLE_MODERATORS=you@gmail.com

# Dev local (/admin) : les médias utilisent /public (studio.media.external=false).
# Ne pas ajouter de bindings D1/R2 dans wrangler.jsonc : NuxtHub les génère au build
# et des doublons bloquent `wrangler deploy`.
