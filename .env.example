# Public URL, used for OG Image when running nuxt generate
NUXT_PUBLIC_SITE_URL=testsetests

# Nuxt Studio (production /admin)
STUDIO_GOOGLE_CLIENT_ID=
STUDIO_GOOGLE_CLIENT_SECRET=
STUDIO_GITHUB_TOKEN=
STUDIO_GOOGLE_MODERATORS=you@gmail.com
# Or use Nuxt runtime config (works well on Cloudflare Pages):
# NUXT_STUDIO_GOOGLE_MODERATORS=you@gmail.com
