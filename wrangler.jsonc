{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "cercle-amical",
  "compatibility_date": "2025-12-12",
  "compatibility_flags": ["nodejs_compat", "nodejs_compat_populate_process_env"],
  "keep_vars": true,
  "r2_buckets": [
    {
      "binding": "BLOB",
      "bucket_name": "cercle-amical-media",
      "remote": true
    }
  ],
  "assets": {
    "directory": "./.output/public"
  }
}
